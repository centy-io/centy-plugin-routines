{
  "name": "centy-plugin-routines",
  "version": "0.3.0",
  "description": "A Centy plugin that ships with a curated pool of routines — predefined repeatable processes, checklists, and workflows.",
  "type": "module",
  "bin": {
    "centy-plugin-routines": "./dist/index.js"
  },
  "files": [
    "dist",
    "routines"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "centy",
    "plugin",
    "routines",
    "checklists",
    "workflows"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/centy-io/centy-plugin-routines.git"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.39.3",
    "eslint-config-agent": "^2.1.0",
    "typescript": "^5.7.0"
  }
}
